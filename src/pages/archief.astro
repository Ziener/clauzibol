---
import Layout from "../layouts/Layout.astro";
import { weeks, isUnlocked, formatNL } from "../data/weeks";
---
<Layout title="Archief — Clauzibol">
  <section class="max-w-4xl mx-auto px-6 py-16">
    <p class="text-xs uppercase tracking-[0.3em]" style="color:var(--color-gold)">Alle 52 weken</p>
    <h1 class="serif text-4xl md:text-5xl mt-3 mb-10" style="color:var(--color-cream)">Archief</h1>

    <ul class="divide-y" style="border-color:rgba(255,255,255,0.06)">
      {weeks.map((w) => {
        const open = isUnlocked(w);
        return (
          <li class="py-4 flex items-center justify-between gap-4" style="border-color:rgba(255,255,255,0.06)">
            <div class="flex items-center gap-4 min-w-0">
              <span class="text-lg shrink-0">{open ? "🔓" : "🔒"}</span>
              <div class="min-w-0">
                <a href={`/blog/${w.slug}`} class="serif text-lg block truncate" style="color:var(--color-cream)">
                  Week {String(w.number).padStart(2, "0")} — {w.title}
                </a>
                <div class="text-xs opacity-60">{formatNL(w.unlockISO)}</div>
              </div>
            </div>
            <span class="text-xs uppercase tracking-widest shrink-0" style={open ? "color:var(--color-gold)" : "color:rgba(255,255,255,0.4)"}>
              {open ? "open" : "verzegeld"}
            </span>
          </li>
        );
      })}
    </ul>
  </section>
</Layout>
