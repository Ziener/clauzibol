---
import Layout from "../layouts/Layout.astro";
---
<Layout title="Contact & Nieuwsbrief — Clauzibol">
  <section class="max-w-2xl mx-auto px-6 py-16">
    <p class="text-xs uppercase tracking-[0.3em]" style="color:var(--color-gold)">Contact</p>
    <h1 class="serif text-4xl md:text-5xl mt-3 mb-6" style="color:var(--color-cream)">Schrijf je in. Of stuur ons een bericht.</h1>
    <p class="opacity-90 mb-10">
      Elke maandag om 07:00 uur opent het volgende slot. Wil je een seintje per e-mail? Schrijf je hieronder
      in — dubbele opt-in, geen spam, één mailtje per week.
    </p>

    <form
      class="rounded-lg border p-6 mb-10"
      style="border-color:rgba(184,134,11,0.3);background:rgba(184,134,11,0.04)"
      action="https://formspree.io/f/your-form-id"
      method="POST"
    >
      <label class="block text-sm mb-2" style="color:var(--color-gold-soft)">E-mailadres</label>
      <input
        type="email"
        name="email"
        required
        placeholder="naam@voorbeeld.nl"
        class="w-full rounded px-3 py-2 mb-4 bg-transparent border"
        style="border-color:rgba(184,134,11,0.4);color:var(--color-cream)"
      />
      <button type="submit" class="px-5 py-2.5 rounded text-sm" style="background:var(--color-gold);color:var(--color-night)">
        Inschrijven
      </button>
    </form>

    <h2 class="serif text-2xl mt-12 mb-4" style="color:var(--color-gold)">Vragen of reacties?</h2>
    <form
      class="rounded-lg border p-6"
      style="border-color:rgba(255,255,255,0.08)"
      action="https://formspree.io/f/your-form-id"
      method="POST"
    >
      <label class="block text-sm mb-2" style="color:var(--color-gold-soft)">Naam</label>
      <input type="text" name="name" required class="w-full rounded px-3 py-2 mb-4 bg-transparent border" style="border-color:rgba(255,255,255,0.15);color:var(--color-cream)" />

      <label class="block text-sm mb-2" style="color:var(--color-gold-soft)">E-mail</label>
      <input type="email" name="email" required class="w-full rounded px-3 py-2 mb-4 bg-transparent border" style="border-color:rgba(255,255,255,0.15);color:var(--color-cream)" />

      <label class="block text-sm mb-2" style="color:var(--color-gold-soft)">Bericht</label>
      <textarea name="message" rows="5" required class="w-full rounded px-3 py-2 mb-4 bg-transparent border" style="border-color:rgba(255,255,255,0.15);color:var(--color-cream)"></textarea>

      <button type="submit" class="px-5 py-2.5 rounded text-sm border" style="border-color:var(--color-gold);color:var(--color-gold)">
        Versturen
      </button>
    </form>

    <div class="mt-10 text-sm opacity-80 space-y-1">
      <p>Of mail direct: <a href="mailto:info@clauzibol.nl">info@clauzibol.nl</a></p>
      <p>Volg op: <a href="https://instagram.com/clauzibol" target="_blank" rel="noopener">Instagram</a> · <a href="https://facebook.com/clauzibol" target="_blank" rel="noopener">Facebook</a></p>
    </div>
  </section>
</Layout>
