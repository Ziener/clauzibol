---
import Layout from "../layouts/Layout.astro";
import Tile from "../components/Tile.astro";
import Countdown from "../components/Countdown.astro";
import HashProof from "../components/HashProof.astro";
import { weeks, isUnlocked } from "../data/weeks";

const next = weeks.find((w) => !isUnlocked(w));
const openCount = weeks.filter((w) => isUnlocked(w)).length;
---
<Layout>
  <section class="max-w-6xl mx-auto px-6 pt-16 pb-12">
    <div class="max-w-3xl">
      <p class="text-xs uppercase tracking-[0.3em] mb-4" style="color:var(--color-gold)">Plauzibele profetie · Verzegeld 20 april 2026</p>
      <h1 class="serif text-4xl md:text-6xl leading-tight mb-6" style="color:var(--color-cream)">
        52 blogs.<br />
        Vooraf geschreven.<br />
        <span style="color:var(--color-gold)">Eén slot per week.</span>
      </h1>
      <p class="text-lg leading-relaxed opacity-90 mb-8">
        Op <strong>20 april 2026</strong> heeft Claude (AI) 52 blogs geschreven met de Bijbel (HSV) in de hand.
        Alle 52 zijn cryptografisch verzegeld via <em>time-lock encryption</em> en vastgelegd in een publieke
        hash-lijst, ook op de blockchain. Elke maandag om 07:00 uur gaat er één slot open.
        <strong>Niemand</strong>, ook Claude en de maker niet, kan de tekst eerder lezen of nog aanpassen.
      </p>
      <div class="flex flex-wrap gap-3">
        <a href="/manifest" class="px-5 py-2.5 rounded border text-sm" style="border-color:var(--color-gold);color:var(--color-gold)">Lees het manifest</a>
        <a href="/verificatie" class="px-5 py-2.5 rounded text-sm" style="background:var(--color-gold);color:var(--color-night)">Hoe werkt verzegeling?</a>
      </div>
    </div>
  </section>

  {next && (
    <section class="max-w-6xl mx-auto px-6 py-10">
      <div class="rounded-xl border p-6 md:p-8" style="border-color:rgba(184,134,11,0.3);background:rgba(184,134,11,0.04)">
        <p class="text-xs uppercase tracking-widest mb-2" style="color:var(--color-gold)">Volgend slot opent</p>
        <h2 class="serif text-2xl mb-1" style="color:var(--color-cream)">Week {next.number} <span class="italic opacity-60">Verzegeld</span></h2>
        <p class="text-sm opacity-70 mb-6">Vrijgave: {new Date(next.unlockISO).toLocaleString("nl-NL", { dateStyle: "full", timeStyle: "short" })}</p>
        <Countdown target={next.unlockISO} />
      </div>
    </section>
  )}

  <section class="max-w-6xl mx-auto px-6 py-12">
    <div class="flex items-end justify-between mb-6">
      <div>
        <h2 class="serif text-3xl" style="color:var(--color-cream)">De 52 zegels</h2>
        <p class="text-sm opacity-70 mt-1">{openCount} geopend · {52 - openCount} verzegeld</p>
      </div>
      <a href="/blogs" class="text-sm hidden md:block">Alle blogs →</a>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-3">
      {weeks.map((w) => <Tile week={w} />)}
    </div>
  </section>

  <HashProof />

  <section class="max-w-4xl mx-auto px-6 py-16 text-center">
    <p class="serif text-2xl md:text-3xl leading-snug opacity-90 mb-6" style="color:var(--color-cream)">
      "Wat verborgen was, zal worden geopenbaard."
    </p>
    <p class="text-sm opacity-70 mb-8">Geen sensatie. Wel bezinning. Plauzibele profetie, waterdicht bewijsbaar.</p>

    <form
      id="nieuwsbriefForm"
      class="max-w-md mx-auto rounded-lg border p-6 space-y-3 text-left"
      style="border-color:rgba(184,134,11,0.3);background:rgba(184,134,11,0.04)"
    >
      <label for="nb-email" class="block text-sm font-semibold" style="color:var(--color-gold-soft)">
        Schrijf je in voor de wekelijkse release
      </label>
      <p class="text-xs opacity-70">Elke maandagochtend een mailtje zodra het nieuwe slot opent. Eén klik uitschrijven, geen spam.</p>

      <input type="hidden" name="_subject" value="Nieuwsbrief-inschrijving clauzibol.nl" />
      <input type="hidden" name="_template" value="table" />
      <input type="hidden" name="Bron" value="homepage" />

      <!-- Honeypot: leeg veld dat alleen bots invullen -->
      <div style="position:absolute;left:-9999px;top:auto;width:1px;height:1px;overflow:hidden" aria-hidden="true">
        <label>Vul dit veld niet in <input type="text" name="_honey" tabindex="-1" autocomplete="off" /></label>
      </div>

      <div class="flex flex-col sm:flex-row gap-2">
        <input id="nb-email" type="email" name="E-mail" required autocomplete="email"
          placeholder="jij@voorbeeld.nl"
          class="flex-1 rounded px-3 py-2 bg-transparent border focus:outline-none focus:ring-1 text-sm"
          style="border-color:rgba(184,134,11,0.4);color:var(--color-cream)" />
        <button id="nb-submit" type="submit"
          class="px-5 py-2 rounded text-sm font-semibold disabled:opacity-50 disabled:cursor-not-allowed"
          style="background:var(--color-gold);color:var(--color-night)">
          Inschrijven
        </button>
      </div>
      <p class="text-[11px] opacity-60">
        Door in te schrijven ga je akkoord met onze <a href="/colofon" class="underline">privacyverklaring</a>.
      </p>
    </form>
    <div id="nb-status" class="max-w-md mx-auto mt-4 hidden rounded-lg border p-3 text-sm text-left"></div>
  </section>

  <script is:inline>
    (function () {
      const form = document.getElementById("nieuwsbriefForm");
      if (!form) return;
      const btn = document.getElementById("nb-submit");
      const status = document.getElementById("nb-status");
      // Eigen Vercel API route → voegt toe aan Brevo-lijst
      const endpoint = "/api/subscribe";
      const loadedAt = Date.now();

      function show(msg, ok) {
        status.className = "max-w-md mx-auto mt-4 rounded-lg border p-3 text-sm text-left " +
          (ok ? "border-[color:var(--color-gold)]" : "border-red-500/40");
        status.style.background = ok ? "rgba(184,134,11,0.1)" : "rgba(239,68,68,0.08)";
        status.style.color = "var(--color-cream)";
        status.textContent = msg;
        status.classList.remove("hidden");
      }

      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        if (form._honey && form._honey.value) return;
        if (Date.now() - loadedAt < 2000) {
          show("Even rustig aan, vul je e-mail zorgvuldig in.", false);
          return;
        }

        btn.disabled = true;
        btn.textContent = "Bezig...";

        try {
          const data = new FormData(form);
          const obj = {};
          data.forEach((v, k) => { obj[k] = v; });
          const res = await fetch(endpoint, {
            method: "POST",
            headers: { "Content-Type": "application/json", "Accept": "application/json" },
            body: JSON.stringify({ email: obj["E-mail"], _honey: obj._honey, Bron: obj.Bron }),
          });
          const json = await res.json().catch(() => ({}));
          if (res.ok && json.ok) {
            form.reset();
            const msg = json.already
              ? "✓ Je stond al op de lijst. Elke maandagochtend hoor je van ons."
              : "✓ Bedankt, je staat op de lijst. Elke maandagochtend hoor je van ons.";
            show(msg, true);
            btn.textContent = "Ingeschreven";
          } else {
            show("Er ging iets mis: " + (json.error || res.status) + ". Probeer het zo opnieuw.", false);
            btn.disabled = false;
            btn.textContent = "Inschrijven";
          }
        } catch (err) {
          console.error("[nieuwsbrief] fetch error:", err);
          show("Geen verbinding: " + (err && err.message ? err.message : String(err)) + ".", false);
          btn.disabled = false;
          btn.textContent = "Inschrijven";
        }
      });
    })();
  </script>
</Layout>
